# =============================================================================
# Sub2API + NextChat Integration — Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#   nano .env
#
# Then start with: docker compose up -d
#   bash setup.sh
# =============================================================================

# Server mode: release or debug
SERVER_MODE=release

# -----------------------------------------------------------------------------
# Logging Configuration
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别：debug/info/warn/error
LOG_LEVEL=info
# 日志格式：json/console
LOG_FORMAT=console
# 每条日志附带的 service 字段
LOG_SERVICE_NAME=sub2api
# 每条日志附带的 env 字段
LOG_ENV=development
# 是否输出调用方位置信息
LOG_CALLER=true

# 是否输出到 stdout/stderr
LOG_OUTPUT_TO_STDOUT=true
# 是否输出到文件
LOG_OUTPUT_TO_FILE=false

# Global max request body size in bytes (default: 256MB)
SERVER_MAX_REQUEST_BODY_SIZE=268435456

# Gateway max request body size in bytes (default: 256MB)
GATEWAY_MAX_BODY_SIZE=268435456

# Enable HTTP/2 Cleartext (h2c) for client connections
SERVER_H2C_ENABLED=true

# 运行模式: standard (默认) 或 simple (内部自用)
RUN_MODE=standard

# Timezone
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# POSTGRES_USER=sub2api
# POSTGRES_PASSWORD=change_this_password
# POSTGRES_DB=sub2api
DATABASE_PORT=5432

# -----------------------------------------------------------------------------
# Database Connection Pool
# -----------------------------------------------------------------------------
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# -----------------------------------------------------------------------------
# Admin Account (auto-created on first run)
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=admin123456

# -----------------------------------------------------------------------------
# JWT（固定密钥防止重启后登录失效）
# -----------------------------------------------------------------------------
# JWT_SECRET=
JWT_EXPIRE_HOUR=24

# -----------------------------------------------------------------------------
# TOTP（固定密钥防止重启后 2FA 失效）
# -----------------------------------------------------------------------------
# TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Domain Configuration (Caddy 多域名)
# -----------------------------------------------------------------------------
# 主站域名，例如 www.example.com
SITE_DOMAIN=www.example.com
# API 专用域名，仅暴露 /v1/* 接口，例如 api.example.com
API_DOMAIN=api.example.com

# -----------------------------------------------------------------------------
# NextChat
# -----------------------------------------------------------------------------
# NEXTCHAT_CODE=

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=true
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true

# -----------------------------------------------------------------------------
# Update Configuration（国内服务器需配置代理）
# -----------------------------------------------------------------------------
# UPDATE_PROXY_URL=http://host:port
