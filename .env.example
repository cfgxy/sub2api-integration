# ============================================================================
# Sub2API Integration Platform — Optional Environment Overrides
# ============================================================================
# All variables have secure defaults — this file is OPTIONAL.
# Only override values you need to change.
#
# Usage:
#   cp .env.example .env   # only if you need custom values
#   docker compose up -d
# ============================================================================

# ─── Domain ─────────────────────────────────────────────────────────────────
EXTERNAL_URL=http://localhost

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=sub2api_pg_dev
POSTGRES_USER=sub2api

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── Sub2API Admin ──────────────────────────────────────────────────────────
SUB2API_ADMIN_EMAIL=admin@example.com
SUB2API_ADMIN_PASSWORD=admin123456
JWT_SECRET=
TOTP_ENCRYPTION_KEY=

# ─── NextChat ───────────────────────────────────────────────────────────────
NEXTCHAT_CODE=

# ─── Dify ───────────────────────────────────────────────────────────────────
DIFY_VERSION=1.15.0
DIFY_SECRET_KEY=dify-dev-secret-key-change-me
DIFY_SUB2API_CLIENT_SECRET=dify_sub2api_secret
